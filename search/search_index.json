 My OpenCode","text":"<p>\u57fa\u4e8e OpenCode \u7684\u201c\u7f16\u6392\u5c42\u201d\u63d2\u4ef6\uff1a\u591a Agent \u8c03\u5ea6\u3001Hooks\u3001MCP\u3001LSP \u7b49\u3002</p> <ul> <li>\u5b98\u7f51</li> <li>\u5b89\u88c5\u8bf4\u660e</li> <li>GitHub</li> </ul>"},{"location":"tools/programming/ai/#_3","title":"\u5b89\u88c5\u65b9\u5f0f","text":"<pre><code>bunx oh-my-opencode install\n</code></pre>"},{"location":"tools/programming/ai/#opencode-antigravity-auth","title":"opencode-antigravity-auth","text":"<p>\u4f5c\u7528\uff1a\u8ba9 OpenCode \u901a\u8fc7 OAuth \u4f7f\u7528 Google Antigravity \u7684\u989d\u5ea6\uff0c\u767d\u5ad6 Gemini 3 / Claude \u7b49\u6a21\u578b\u3002</p> <ul> <li>GitHub </li> </ul>"},{"location":"tools/programming/ai/#oauth","title":"\u6267\u884c OAuth \u767b\u5f55","text":"<pre><code>opencode auth login\n</code></pre>"},{"location":"tools/programming/ai/#antigravity-manager","title":"Antigravity-Manager","text":"<p>\u4f5c\u7528\uff1a\u4e13\u4e1a\u7684 Antigravity \u8d26\u53f7\u7ba1\u7406\u4e0e\u4e00\u952e\u5207\u6362 + \u534f\u8bae\u4e2d\u8f6c\uff08OpenAI / Anthropic / Gemini\uff09\uff0c\u505a\u672c\u5730 AI \u7f51\u5173\u3002</p> <ul> <li>GitHub\uff1a  </li> </ul>"},{"location":"tools/programming/ai/#_4","title":"\u5b89\u88c5","text":"<pre><code># 1. \u6dfb\u52a0 Tap\nbrew tap lbjlaq/antigravity-manager https://github.com/lbjlaq/Antigravity-Manager\n\n# 2. \u5b89\u88c5\u5e94\u7528\nbrew install --cask antigravity-tools\n# \u5982\u9047\u5b89\u5168\u9650\u5236\u53ef\u7528\uff1a\n# brew install --cask --no-quarantine antigravity-tools\n</code></pre>"},{"location":"tools/programming/ai/#quotio","title":"quotio","text":"<ul> <li>Github</li> </ul>"},{"location":"tools/programming/ai/#hapi","title":"HAPI","text":"<ul> <li>Github</li> </ul>"},{"location":"tools/programming/ai/#happy","title":"happy","text":"<ul> <li>Github</li> </ul>"}]}